# -----------------------------------------------------------------------------
# Go：可执行文件与插件 / Binaries for programs and plugins
# -----------------------------------------------------------------------------
*.exe
*.exe~
*.dll
*.so
*.dylib

# `go test -c` 生成的测试二进制 / Test binary built with go test -c
*.test

# -----------------------------------------------------------------------------
# Go：测试结果与覆盖率 / Test output and coverage
# -----------------------------------------------------------------------------
*.out
coverage.*
*.coverprofile
profile.cov

# -----------------------------------------------------------------------------
# Go：依赖目录（使用 go mod、不提交 vendor 时保持忽略）/ Vendored modules
# -----------------------------------------------------------------------------
vendor/

# -----------------------------------------------------------------------------
# Go：workspace 本地配置 / Local workspace file
# -----------------------------------------------------------------------------
go.work
go.work.sum

# -----------------------------------------------------------------------------
# 本地环境与密钥（勿提交）/ Local env and secrets
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example

# -----------------------------------------------------------------------------
# 操作系统 / OS
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# 编辑器与 IDE / Editors
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
